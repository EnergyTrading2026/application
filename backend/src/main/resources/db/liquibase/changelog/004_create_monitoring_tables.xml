<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation=
        "http://www.liquibase.org/xml/ns/dbchangelog
       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">
    <changeSet id="004-create-monitoring-system" author="mtarp">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="monitoring_system"/>
            </not>
        </preConditions>
        
        <createTable tableName="monitoring_system">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_monitoring_system" nullable="false"/>
            </column>
            <column name="heat_demand" type="DOUBLE PRECISION">
                <constraints nullable="false"/>
            </column>
            <column name="electricity_price" type="DOUBLE PRECISION">
                <constraints nullable="false"/>
            </column>
            <column name="gas_price" type="DOUBLE PRECISION">
                <constraints nullable="false"/>
            </column>
            <column name="timestamp" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <createIndex tableName="monitoring_system" indexName="idx_monitoring_system_timestamp">
            <column name="timestamp"/>
        </createIndex>
        
        <rollback>
            <dropTable tableName="monitoring_system"/>
        </rollback>
    </changeSet>
    
    <changeSet id="004-create-monitoring-asset" author="mtarp">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="monitoring_asset"/>
            </not>
        </preConditions>
        
        <createTable tableName="monitoring_asset">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_monitoring_asset" nullable="false"/>
            </column>
            <column name="asset_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="icon" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="thermal_output" type="DOUBLE PRECISION">
                <constraints nullable="false"/>
            </column>
            <column name="thermal_output_unit" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="network_output" type="DOUBLE PRECISION">
                <constraints nullable="false"/>
            </column>
            <column name="input" type="DOUBLE PRECISION">
                <constraints nullable="false"/>
            </column>
            <column name="input_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="input_unit" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="input_cost" type="DOUBLE PRECISION">
                <constraints nullable="false"/>
            </column>
            <column name="electrical_output" type="DOUBLE PRECISION">
                <constraints nullable="true"/>
            </column>
            <column name="electrical_output_unit" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
            <column name="electrical_output_revenue" type="DOUBLE PRECISION">
                <constraints nullable="true"/>
            </column>
            <column name="timestamp" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <createIndex tableName="monitoring_asset" indexName="idx_monitoring_asset_timestamp">
            <column name="timestamp"/>
        </createIndex>
        
        <rollback>
            <dropTable tableName="monitoring_asset"/>
        </rollback>
    </changeSet>
    
    <changeSet id="004-create-monitoring-storage" author="mtarp">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="monitoring_storage"/>
            </not>
        </preConditions>
        
        <createTable tableName="monitoring_storage">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_monitoring_storage" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="percent" type="DOUBLE PRECISION">
                <constraints nullable="false"/>
            </column>
            <column name="capacity" type="DOUBLE PRECISION">
                <constraints nullable="false"/>
            </column>
            <column name="charging" type="DOUBLE PRECISION">
                <constraints nullable="false"/>
            </column>
            <column name="discharge" type="DOUBLE PRECISION">
                <constraints nullable="false"/>
            </column>
            <column name="net_balance" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="range" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="timestamp" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <createIndex tableName="monitoring_storage" indexName="idx_monitoring_storage_timestamp">
            <column name="timestamp"/>
        </createIndex>
        
        <rollback>
            <dropTable tableName="monitoring_storage"/>
        </rollback>
    </changeSet>
    
    <changeSet id="004-create-monitoring-metric" author="mtarp">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="monitoring_metric"/>
            </not>
        </preConditions>
        
        <createTable tableName="monitoring_metric">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_monitoring_metric" nullable="false"/>
            </column>
            <column name="storage_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="label" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="value" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="timestamp" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <addForeignKeyConstraint
                baseTableName="monitoring_metric"
                baseColumnNames="storage_id"
                referencedTableName="monitoring_storage"
                referencedColumnNames="id"
                constraintName="fk_monitoring_metric_storage"
                onDelete="CASCADE"/>
        
        <createIndex tableName="monitoring_metric" indexName="idx_monitoring_metric_timestamp">
            <column name="timestamp"/>
        </createIndex>
        
        <createIndex tableName="monitoring_metric" indexName="idx_monitoring_metric_storage">
            <column name="storage_id"/>
        </createIndex>
        
        <rollback>
            <dropTable tableName="monitoring_metric"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
